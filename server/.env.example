# Copy this file to .env and fill in values before starting the server.

# REQUIRED: Random secret used to encrypt the GitHub PAT at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this after a PAT is stored will make the stored token unreadable.
SERVER_SECRET=replace-with-a-long-random-string

# Optional: port to listen on (default: 3000)
# PORT=3000
